{
  "cleanUrls": true,
  "functions": {
    "api/poster.js": { "maxDuration": 60 }
  },
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/success.html", "destination": "/success", "permanent": true },
    { "source": "/verify.html", "destination": "/verify", "permanent": true },
    { "source": "/admin.html", "destination": "/admin", "permanent": true },
    { "source": "/nominees.html", "destination": "/admin?tab=nominees", "permanent": true },
    { "source": "/nominees", "destination": "/admin?tab=nominees", "permanent": true },
    { "source": "/orders.html", "destination": "/admin?tab=orders", "permanent": true },
    { "source": "/orders", "destination": "/admin?tab=orders", "permanent": true }
  ],
  "rewrites": [
    { "source": "/v/:order", "destination": "/verify?order=:order" },
    { "source": "/api/verify", "destination": "/api/order-query?mode=verify" },
    { "source": "/api/order-status", "destination": "/api/order-query?mode=status" },
    { "source": "/api/nominees", "destination": "/api/admin?resource=nominees" },
    { "source": "/api/orders-admin", "destination": "/api/admin?resource=orders" }
  ]
}
